<UserControl x:Class="FakultetApp.Views.StudentViews.StudentDashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1200">

    <UserControl.Resources>
        <!-- STIL ZA HORIZONTALNE TAB DUGMAD -->
        <Style x:Key="NavTabButtonStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Grid Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center" 
                                              Margin="{TemplateBinding Padding}"/>

                            <!-- Indikator aktivnog taba (donja linija) -->
                            <Border x:Name="ActiveIndicator" 
                                    Height="3" 
                                    Background="{DynamicResource AccentColor}" 
                                    VerticalAlignment="Bottom" 
                                    Visibility="Hidden"
                                    CornerRadius="2,2,0,0"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource AccentColor}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource AccentColor}"/>
                                <Setter TargetName="ActiveIndicator" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="{DynamicResource WindowBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <!-- Horizontalni Header -->
            <RowDefinition Height="*"/>
            <!-- Prikaz sadržaja -->
        </Grid.RowDefinitions>

        <!-- HORIZONTALNI HEADER NA VRHU -->
        <Border Grid.Row="0" 
                Background="{DynamicResource CardBackground}" 
                BorderBrush="{DynamicResource BorderColor}" 
                BorderThickness="0,0,0,1">
            <Grid Margin="15,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <!-- Logo / Naslov -->
                    <ColumnDefinition Width="*"/>
                    <!-- Meni Tabovi -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- Odjava -->
                </Grid.ColumnDefinitions>

                <!-- Naslov sekcije / Logo -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,20,0">
                    <TextBlock Text="🎓" FontSize="20" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="STUDENT PORTAL" 
                               FontSize="16" 
                               FontWeight="Bold" 
                               Foreground="{DynamicResource Naslov}" 
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Horizontalni Tabovi -->
                <ScrollViewer Grid.Column="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Stretch">
                        <RadioButton x:Name="btnPocetna" 
                                     Content="🏠 Početna" 
                                     Style="{StaticResource NavTabButtonStyle}" 
                                     IsChecked="True" 
                                     Click="Nav_Click"/>

                        <RadioButton x:Name="btnObjave" 
                                     Content="📢 Objave" 
                                     Style="{StaticResource NavTabButtonStyle}" 
                                     Click="Nav_Click"/>

                        <RadioButton x:Name="btnDokumenti" 
                                     Content="📁 Dokumenti" 
                                     Style="{StaticResource NavTabButtonStyle}" 
                                     Click="Nav_Click"/>

                        <RadioButton x:Name="btnPrijavaIspita" 
                                     Content="📝 Prijava ispita" 
                                     Style="{StaticResource NavTabButtonStyle}" 
                                     Click="Nav_Click"/>

                        <RadioButton x:Name="btnZahtjevPotvrda" 
                                     Content="📄 Zahtjev za potvrdu" 
                                     Style="{StaticResource NavTabButtonStyle}" 
                                     Click="Nav_Click"/>

                        <RadioButton x:Name="btnChat" 
                                     Content="💬 Chat" 
                                     Style="{StaticResource NavTabButtonStyle}" 
                                     Click="Nav_Click"/>

                        <RadioButton x:Name="btnLicniPodaci" 
                                     Content="👤 Lični podaci" 
                                     Style="{StaticResource NavTabButtonStyle}" 
                                     Click="Nav_Click"/>
                    </StackPanel>
                </ScrollViewer>

                <!-- Odjava -->
                <Button Grid.Column="2" 
                        x:Name="btnOdjava" 
                        Content="⬅️ Odjava" 
                        Click="Nav_Click" 
                        Height="34" 
                        Padding="12,0" 
                        Background="Transparent" 
                        Foreground="{DynamicResource Error}" 
                        BorderBrush="{DynamicResource Error}"
                        BorderThickness="1"
                        Cursor="Hand"
                        VerticalAlignment="Center">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="4"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>
        </Border>

        <!-- PRIKAZNIK SADRŽAJA (Zajednički kontejner za podstranice) -->
        <Grid Grid.Row="1" Margin="20">
            <ContentControl x:Name="PrikaznikSadrzaja"/>
        </Grid>
    </Grid>
</UserControl>
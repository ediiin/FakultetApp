<UserControl x:Class="FakultetApp.Views.Admin.Asistenti.AsistentPregledView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FakultetApp.Views.Admin.Asistenti"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Background="#F5F5F5" Padding="10" CornerRadius="5" Margin="0,0,0,15">
            <StackPanel Orientation="Horizontal">
                <StackPanel Margin="0,0,15,0">
                    <TextBlock Text="Pretraga po imenu i prezimenu:" Margin="0,0,0,5" FontWeight="Bold"/>
                    <TextBox Name="txtFilter" Width="350" Height="25" TextChanged="Filter_TextChanged"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <DataGrid Name="dgvAsistenti" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" AlternatingRowBackground="#F9F9F9">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Plata" Binding="{Binding Plata, StringFormat={}{0:N2}}" Width="150"/>
                <DataGridTextColumn Header="Ime i prezime" Binding="{Binding ImePrezime}" Width="*"/>

                <DataGridTemplateColumn Header="Akcija" Width="150">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Name="btnObrisi"
                                    Content="Ukloni asistenta"
                                    Background="#FF4D4D"
                                    Foreground="White"
                                    FontWeight="Bold"
                                    Padding="5,2"
                                    Click="BtnObrisi_Click"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>

<UserControl x:Class="FakultetApp.Views.Admin.Asistenti.AsistentPregledView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FakultetApp.Views.Admin.Asistenti"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Okvir za pretragu -->
        <Border Background="{DynamicResource CardBackground}" 
                BorderBrush="{DynamicResource BorderColor}" 
                BorderThickness="1"
                Padding="10" 
                CornerRadius="5" 
                Margin="0,0,0,15">
            <StackPanel Orientation="Horizontal">
                <StackPanel Margin="0,0,15,0">
                    <TextBlock Text="Pretraga po imenu i prezimenu:" 
                               Margin="0,0,0,5" 
                               Foreground="{DynamicResource PrimaryText}"
                               FontWeight="Bold"/>
                    <TextBox Name="txtFilter" 
                             Width="350" 
                             Height="25" 
                             Background="{DynamicResource WindowBackground}"
                             Foreground="{DynamicResource PrimaryText}"
                             BorderBrush="{DynamicResource BorderColor}"
                             VerticalContentAlignment="Center"
                             Padding="3,0"
                             TextChanged="Filter_TextChanged"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- DataGrid OČIŠĆEN od lokalnih stilova -->
        <DataGrid Name="dgvAsistenti"
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  Background="{DynamicResource CardBackground}"
                  AlternatingRowBackground="{DynamicResource WindowBackground}"
                  BorderBrush="{DynamicResource BorderColor}"
                  HorizontalGridLinesBrush="{DynamicResource BorderColor}"
                  VerticalGridLinesBrush="{DynamicResource BorderColor}"
                  HeadersVisibility="Column"
                  BorderThickness="1" 
                  MouseDoubleClick="dgvAsistenti_MouseDoubleClick">

            <!-- STIL ZA ZAGLAVLJE DATAGRIDA (Jedini koji ostavljamo lokalno jer ti fali u ResourceDictionary) -->
            <DataGrid.Resources>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="{DynamicResource BorderColor}" />
                    <Setter Property="Foreground" Value="{DynamicResource PrimaryText}" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                    <Setter Property="Padding" Value="10,8" />
                    <Setter Property="BorderBrush" Value="{DynamicResource WindowBackground}" />
                    <Setter Property="BorderThickness" Value="0,0,1,1" />
                </Style>
            </DataGrid.Resources>

            <DataGrid.Columns>
                <DataGridTextColumn Header="Plata" Binding="{Binding Plata, StringFormat={}{0:N2}}" Width="150"/>
                <DataGridTextColumn Header="Ime i prezime" Binding="{Binding ImePrezime}" Width="*"/>

                <DataGridTemplateColumn Header="Akcija" Width="150">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Name="btnObrisi"
                                    Content="Ukloni asistenta"
                                    Background="{DynamicResource Error}"
                                    Foreground="White"
                                    FontWeight="Bold"
                                    Padding="5,2"
                                    Cursor="Hand"
                                    Click="BtnObrisi_Click"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
<UserControl x:Class="FakultetApp.Views.Admin.Asistenti.AsistentiEditView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FakultetApp.Views.Admin.Asistenti"
             mc:Ignorable="d" 
             VerticalAlignment="Stretch"
             HorizontalAlignment="Stretch">

    <Grid Background="{DynamicResource WindowBackground}">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
            <Border Background="{DynamicResource CardBackground}"
                    BorderBrush="{DynamicResource BorderColor}"
                    BorderThickness="1"
                    CornerRadius="8" 
                    Padding="30" 
                    MinWidth="900"
                    HorizontalAlignment="Left" 
                    VerticalAlignment="Top"
                    Margin="20">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Row 0: Ime & Prezime (EDITABILNO) -->
                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,15">
                        <TextBlock Text="Ime" Foreground="{DynamicResource PrimaryText}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBox Name="tbIme" Background="{DynamicResource WindowBackground}" Foreground="{DynamicResource PrimaryText}" BorderBrush="{DynamicResource BorderColor}" FontSize="15" Padding="5"/>
                        <TextBlock x:Name="lblImeError" Text="" Foreground="{DynamicResource Error}" FontSize="10" FontWeight="SemiBold" Margin="0,3,0,0" Visibility="Hidden"/>
                    </StackPanel>

                    <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,15">
                        <TextBlock Text="Prezime" Foreground="{DynamicResource PrimaryText}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBox Name="tbPrezime" Background="{DynamicResource WindowBackground}" Foreground="{DynamicResource PrimaryText}" BorderBrush="{DynamicResource BorderColor}" FontSize="15" Padding="5"/>
                        <TextBlock x:Name="lblPrezimeError" Text="" Foreground="{DynamicResource Error}" FontSize="10" FontWeight="SemiBold" Margin="0,3,0,0" Visibility="Hidden"/>
                    </StackPanel>

                    <!-- Row 1: Korisničko Ime & Email (EDITABILNO) -->
                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,15">
                        <TextBlock Text="Korisničko Ime" Foreground="{DynamicResource PrimaryText}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBox Name="tbKorisnickoIme" Background="{DynamicResource WindowBackground}" Foreground="{DynamicResource PrimaryText}" BorderBrush="{DynamicResource BorderColor}" FontSize="15" Padding="5"/>
                        <TextBlock x:Name="lblKorisnickoImeError" Text="" Foreground="{DynamicResource Error}" FontSize="10" FontWeight="SemiBold" Margin="0,3,0,0" Visibility="Hidden"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,15">
                        <TextBlock Text="Email" Foreground="{DynamicResource PrimaryText}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBox Name="tbEmail" Background="{DynamicResource WindowBackground}" Foreground="{DynamicResource PrimaryText}" BorderBrush="{DynamicResource BorderColor}" FontSize="15" Padding="5"/>
                        <TextBlock x:Name="lblEmailError" Text="" Foreground="{DynamicResource Error}" FontSize="10" FontWeight="SemiBold" Margin="0,3,0,0" Visibility="Hidden"/>
                    </StackPanel>

                    <!-- Row 2: Spol & Grad (ZABRANJEN EDIT) -->
                    <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,0,15">
                        <TextBlock Text="Spol (Nije moguće mijenjati)" Foreground="{DynamicResource PrimaryText}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <ComboBox Name="cmbSpol" FontSize="15" Padding="5" IsEnabled="False"/>
                        <TextBlock x:Name="lblSpolError" Text="" Foreground="{DynamicResource Error}" FontSize="10" FontWeight="SemiBold" Margin="0,3,0,0" Visibility="Hidden"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Grid.Column="2" Margin="0,0,0,15">
                        <TextBlock Text="Grad (Nije moguće mijenjati)" Foreground="{DynamicResource PrimaryText}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <ComboBox Name="cmbGrad" FontSize="15" Padding="5" IsEnabled="False"/>
                        <TextBlock x:Name="lblGradError" Text="" Foreground="{DynamicResource Error}" FontSize="10" FontWeight="SemiBold" Margin="0,3,0,0" Visibility="Hidden"/>
                    </StackPanel>

                    <!-- Row 3: JMBG & Datum Rođenja (ZABRANJEN EDIT) -->
                    <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,0,0,15">
                        <TextBlock Text="JMBG (Nije moguće mijenjati)" Foreground="{DynamicResource PrimaryText}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBox Name="tbJMBG" FontSize="15" Padding="5" IsReadOnly="True" FontWeight="Bold" BorderBrush="{DynamicResource BorderColor}"/>
                        <TextBlock x:Name="lblJMBGError" Text="" Foreground="{DynamicResource Error}" FontSize="10" FontWeight="SemiBold" Margin="0,3,0,0" Visibility="Hidden"/>
                    </StackPanel>

                    <StackPanel Grid.Row="3" Grid.Column="2" Margin="0,0,0,15">
                        <TextBlock Text="Datum Rođenja (Nije moguće mijenjati)" Foreground="{DynamicResource PrimaryText}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <DatePicker Name="dtpDatumRodjenja" FontSize="15" Padding="3" IsEnabled="False"/>
                        <TextBlock x:Name="lblDatumRodjenjaError" Text="" Foreground="{DynamicResource Error}" FontSize="10" FontWeight="SemiBold" Margin="0,3,0,0" Visibility="Hidden"/>
                    </StackPanel>

                    <!-- Row 4: Plata & Nova Lozinka (EDITABILNO) -->
                    <StackPanel Grid.Row="4" Grid.Column="0" Margin="0,0,0,15">
                        <TextBlock Text="Plata (KM)" Foreground="{DynamicResource PrimaryText}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBox Name="tbPlata" Background="{DynamicResource WindowBackground}" Foreground="{DynamicResource PrimaryText}" BorderBrush="{DynamicResource BorderColor}" FontSize="15" Padding="5"/>
                        <TextBlock x:Name="lblPlataError" Text="" Foreground="{DynamicResource Error}" FontSize="10" FontWeight="SemiBold" Margin="0,3,0,0" Visibility="Hidden"/>
                    </StackPanel>

                    <StackPanel Grid.Row="4" Grid.Column="2" Margin="0,0,0,15">
                        <TextBlock Text="Nova Lozinka (Ostavi prazno ako se ne mijenja)" Foreground="{DynamicResource PrimaryText}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <PasswordBox Name="pbLozinka" Background="{DynamicResource WindowBackground}" Foreground="{DynamicResource PrimaryText}" BorderBrush="{DynamicResource BorderColor}" FontSize="15" Padding="5"/>
                        <TextBlock x:Name="lblLozinkaError" Text="" MaxWidth="400" TextWrapping="Wrap" Foreground="{DynamicResource Error}" FontSize="10" FontWeight="SemiBold" Margin="0,3,0,0" Visibility="Hidden"/>
                    </StackPanel>

                    <!-- Row 5: Dugme Sačuvaj Izmjene -->
                    <StackPanel Grid.Row="5" Grid.Column="2" Margin="0,15,0,0" VerticalAlignment="Bottom">
                        <Button Name="btnSacuvajIzmjene"
                                Content="Sačuvaj Izmjene" 
                                FontSize="15" 
                                FontWeight="Bold"
                                Background="{DynamicResource AccentColor}" 
                                Foreground="White" 
                                Padding="50,8" 
                                HorizontalAlignment="Right" 
                                Cursor="Hand" 
                                Click="BtnSpasi_Click" />

                        <TextBlock x:Name="lblDuplikatError" 
                                   Text="" 
                                   Foreground="{DynamicResource Error}" 
                                   FontSize="10" 
                                   FontWeight="SemiBold"
                                   Margin="0,3,0,0" 
                                   HorizontalAlignment="Right"
                                   Visibility="Hidden"/>
                    </StackPanel>
                </Grid>
            </Border>
        </ScrollViewer>
    </Grid>
</UserControl>
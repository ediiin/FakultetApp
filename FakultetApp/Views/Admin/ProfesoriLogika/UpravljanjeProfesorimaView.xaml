<UserControl x:Class="FakultetApp.Views.Admin.ProfesoriLogika.UpravljanjeProfesorimaView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FakultetApp.Views.Admin.ProfesoriLogika"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,20">
            <Button Name="btnPrikaziSve" Content="Prikaži sve profesore" FontSize="15" Width="180" Height="35" Margin="0,0,10,0" Click="ProfesorNav_Click"/>
            <Button Name="btnDodajProfesora" Content="Dodaj novog profesora" FontSize="15" Width="180" Height="35" Margin="30, 5" Click="ProfesorNav_Click"/>
        </StackPanel>

        <ContentControl Name="ProfesoriSadrzaj" Grid.Row="1"/>
    </Grid>
</UserControl>

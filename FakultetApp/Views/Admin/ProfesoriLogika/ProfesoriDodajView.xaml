<UserControl x:Class="FakultetApp.Views.Admin.ProfesoriLogika.ProfesoriDodajView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FakultetApp.Views.Admin.ProfesoriLogika"
             mc:Ignorable="d" 
             VerticalAlignment="Stretch"
             HorizontalAlignment="Stretch">
    <Grid Background="#F5F5F5">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
            <Border Background="White"
                CornerRadius="8" 
                Padding="30" 
                MinWidth="900"
                HorizontalAlignment="Left" 
                VerticalAlignment="Top"
                Margin="20">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,15">
                        <TextBlock Text="Ime" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBox Name="tbIme" FontSize="15" Padding="5"/>
                        <TextBlock x:Name="lblImeError" Text="" Foreground="Red" FontSize="10" FontWeight="SemiBold" Margin="0,3,0,0" Visibility="Hidden"/>
                    </StackPanel>

                    <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,15">
                        <TextBlock Text="Prezime" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBox Name="tbPrezime" FontSize="15" Padding="5"/>
                        <TextBlock x:Name="lblPrezimeError" Text="" Foreground="Red" FontSize="10" FontWeight="SemiBold" Margin="0,3,0,0" Visibility="Hidden"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,15">
                        <TextBlock Text="Korisničko Ime" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBox Name="tbKorisnickoIme" FontSize="15" Padding="5"/>
                        <TextBlock x:Name="lblKorisnickoImeError" Text="" Foreground="Red" FontSize="10" FontWeight="SemiBold" Margin="0,3,0,0" Visibility="Hidden"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,15">
                        <TextBlock Text="Email" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBox Name="tbEmail" FontSize="15" Padding="5"/>
                        <TextBlock x:Name="lblEmailError" Text="" Foreground="Red" FontSize="10" FontWeight="SemiBold" Margin="0,3,0,0" Visibility="Hidden"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,0,15">
                        <TextBlock Text="Spol" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <ComboBox Name="cmbSpol" FontSize="15" Padding="5"/>
                        <TextBlock x:Name="lblSpolError" Text="" Foreground="Red" FontSize="10" FontWeight="SemiBold" Margin="0,3,0,0" Visibility="Hidden"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Grid.Column="2" Margin="0,0,0,15">
                        <TextBlock Text="Grad" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <ComboBox Name="cmbGrad" FontSize="15" Padding="5"/>
                        <TextBlock x:Name="lblGradError" Text="" Foreground="Red" FontSize="10" FontWeight="SemiBold" Margin="0,3,0,0" Visibility="Hidden"/>
                    </StackPanel>

                    <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,0,0,15">
                        <TextBlock Text="JMBG" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBox Name="tbJMBG" FontSize="15" Padding="5"/>
                        <TextBlock x:Name="lblJMBGError" Text="" Foreground="Red" FontSize="10" FontWeight="SemiBold" Margin="0,3,0,0" Visibility="Hidden"/>
                    </StackPanel>

                    <StackPanel Grid.Row="3" Grid.Column="2" Margin="0,0,0,15">
                        <TextBlock Text="Datum Rođenja" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <DatePicker Name="dtpDatumRodjenja" FontSize="15" Padding="3"/>
                        <TextBlock x:Name="lblDatumRodjenjaError" Text="" Foreground="Red" FontSize="10" FontWeight="SemiBold" Margin="0,3,0,0" Visibility="Hidden"/>
                    </StackPanel>

                    <StackPanel Grid.Row="4" Grid.Column="0" Margin="0,0,0,15">
                        <TextBlock Text="Naučno Zvanje" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <ComboBox Name="cmbZvanje" FontSize="15" Padding="5"/>
                        <TextBlock x:Name="lblZvanjeError" Text="Odabir zvanja je obavezan!" Foreground="Red" FontSize="10" FontWeight="SemiBold" Margin="0,3,0,0" Visibility="Hidden"/>
                    </StackPanel>

                    <StackPanel Grid.Row="4" Grid.Column="2" Margin="0,0,0,15">
                        <TextBlock Text="Mesečna Plata (KM)" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBox Name="tbPlata" FontSize="15" Padding="5"/>
                        <TextBlock x:Name="lblPlataError" Text="" Foreground="Red" FontSize="10" FontWeight="SemiBold" Margin="0,3,0,0" Visibility="Hidden"/>
                    </StackPanel>

                    <StackPanel Grid.Row="5" Grid.Column="0" Margin="0,0,0,15">
                        <TextBlock Text="Privremena Lozinka" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <PasswordBox Name="pbLozinka" FontSize="15" Padding="5"/>
                        <TextBlock x:Name="lblLozinkaError" Text="" MaxWidth="400" TextWrapping="Wrap" Foreground="Red" FontSize="10" FontWeight="SemiBold" Margin="0,3,0,0" Visibility="Hidden"/>
                    </StackPanel>

                    <StackPanel Grid.Row="6" Grid.Column="2" Margin="0,15,0,0" VerticalAlignment="Bottom">
                        <Button Name="btnSpasi"
                            Content="Sačuvaj Profesora" 
                            FontSize="15" 
                            FontWeight="Bold"
                            Background="#3182CE" 
                            Foreground="White" 
                            Padding="50,8" 
                            HorizontalAlignment="Right" 
                            Cursor="Hand" 
                            Click="BtnSpasi_Click" />
                    </StackPanel>
                </Grid>
            </Border>
        </ScrollViewer>
    </Grid>
</UserControl>

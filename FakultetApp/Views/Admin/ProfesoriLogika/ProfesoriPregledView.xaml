<UserControl x:Class="FakultetApp.Views.Admin.ProfesoriLogika.ProfesoriPregledView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FakultetApp.Views.Admin.ProfesoriLogika"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Okvir za pretragu -->
        <Border Background="{DynamicResource CardBackground}" 
                BorderBrush="{DynamicResource BorderColor}"
                BorderThickness="1"
                Padding="10" 
                CornerRadius="5" 
                Margin="0,0,0,15">
            <StackPanel Orientation="Horizontal">
                <StackPanel Margin="0,0,15,0">
                    <TextBlock Text="Pretraga po imenu i prezimenu:" 
                               Foreground="{DynamicResource PrimaryText}"
                               Margin="0,0,0,5" 
                               FontWeight="Bold"/>
                    <TextBox Name="txtFilter" 
                             Width="350" 
                             Height="25" 
                             Background="{DynamicResource WindowBackground}"
                             Foreground="{DynamicResource PrimaryText}"
                             BorderBrush="{DynamicResource BorderColor}"
                             VerticalContentAlignment="Center"
                             Padding="3,0"
                             TextChanged="Filter_TextChanged"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- DataGrid sa ugrađenim stilovima -->
        <DataGrid Name="dgvProfesori" 
                  Grid.Row="1" 
                  AutoGenerateColumns="False" 
                  IsReadOnly="True" 
                  Background="{DynamicResource CardBackground}"
                  AlternatingRowBackground="{DynamicResource WindowBackground}"
                  BorderBrush="{DynamicResource BorderColor}"
                  HorizontalGridLinesBrush="{DynamicResource BorderColor}"
                  VerticalGridLinesBrush="{DynamicResource BorderColor}"
                  HeadersVisibility="Column"
                  BorderThickness="1" MouseDoubleClick="dgvProfesori_MouseDoubleClick">

            <!-- STIL ZA ZAGLAVLJE DATAGRIDA -->
            <DataGrid.Resources>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="{DynamicResource BorderColor}" />
                    <Setter Property="Foreground" Value="{DynamicResource PrimaryText}" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                    <Setter Property="Padding" Value="10,8" />
                    <Setter Property="BorderBrush" Value="{DynamicResource WindowBackground}" />
                    <Setter Property="BorderThickness" Value="0,0,1,1" />
                </Style>
            </DataGrid.Resources>

            <DataGrid.Columns>
                <DataGridTextColumn Header="Zvanje" Binding="{Binding ZvanjeOpis}" Width="150"/>
                <DataGridTextColumn Header="Ime i prezime" Binding="{Binding}" Width="*"/>

                <DataGridTemplateColumn Header="Akcija" Width="150">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Name="btnObrisi"
                                    Content="Raskid ugovora"
                                    Background="#FF4D4D"
                                    Foreground="White"
                                    FontWeight="Bold"
                                    Padding="5,2"
                                    Cursor="Hand"
                                    Click="BtnObrisi_Click"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
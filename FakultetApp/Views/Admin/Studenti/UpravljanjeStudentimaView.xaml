<UserControl x:Class="FakultetApp.Views.Admin.UpravljanjeStudentimaView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FakultetApp.Views.Admin"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid >
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,20">
            <Button Name="btnPrikažiSve" Content="Prikaži sve studente" FontSize="15" Width="170" Height="35" Margin="0,0,10,0" Click="StudentNav_Click"/>
            <Button Name="btnDodajStudenta" Content="Dodaj novog studenta" FontSize="15" Width="170" Height="35" Margin="30, 5" Click="StudentNav_Click"/>
        </StackPanel>

        <ContentControl Name="StudentiSadrzaj" Grid.Row="1"/>
    </Grid>
</UserControl>

<UserControl x:Class="FakultetApp.Views.Predmeti.UpravljanjePredmetimaView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FakultetApp.Views.Predmeti"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,20">
            <Button Name="btnPrikaziSve" 
                    Content="Prikaži sve predmete" 
                    FontSize="15" 
                    Width="180" 
                    Height="35" 
                    Margin="0,0,15,0" 
                    Background="{DynamicResource CardBackground}"
                    Foreground="{DynamicResource PrimaryText}"
                    BorderBrush="{DynamicResource BorderColor}"
                    Cursor="Hand"
                    Click="PredmetNav_Click"/>

            <Button Name="btnDodajPredmet" 
                    Content="Dodaj novi predmet" 
                    FontSize="15" 
                    Width="180" 
                    Height="35" 
                    Margin="0,0,0,0" 
                    Background="{DynamicResource CardBackground}"
                    Foreground="{DynamicResource PrimaryText}"
                    BorderBrush="{DynamicResource BorderColor}"
                    Cursor="Hand"
                    Click="PredmetNav_Click"/>
        </StackPanel>

        <ContentControl Name="PredmetiSadrzaj" Grid.Row="1"/>
    </Grid>
</UserControl>
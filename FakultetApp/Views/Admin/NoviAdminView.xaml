<UserControl x:Class="FakultetApp.Views.NoviAdminView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FakultetApp.Views"
             mc:Ignorable="d"
             HorizontalAlignment="Stretch" 
             VerticalAlignment="Stretch">

    <Grid Background="{DynamicResource WindowBackground}">

        <Border Background="{DynamicResource CardBackground}"
                BorderBrush="{DynamicResource BorderColor}"
                BorderThickness="1"
                CornerRadius="8" 
                Padding="30" 
                MinWidth="900"
                HorizontalAlignment="Left" 
                VerticalAlignment="Top">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,15">
                    <TextBlock Text="Ime" Foreground="{DynamicResource PrimaryText}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox Name="tbIme" Background="{DynamicResource WindowBackground}" Foreground="{DynamicResource PrimaryText}" BorderBrush="{DynamicResource BorderColor}" FontSize="15" Padding="5"/>
                    <TextBlock x:Name="lblImeError" 
                        Text="" 
                        Foreground="Red" 
                        FontSize="10" 
                        FontWeight="SemiBold"
                        Margin="0,3,0,0" 
                        Visibility="Hidden"/>
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,15">
                    <TextBlock Text="Prezime" Foreground="{DynamicResource PrimaryText}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox Name="tbPrezime" Background="{DynamicResource WindowBackground}" Foreground="{DynamicResource PrimaryText}" BorderBrush="{DynamicResource BorderColor}" FontSize="15" Padding="5"/>
                    <TextBlock x:Name="lblPrezimeError" 
                        Text="" 
                        Foreground="Red" 
                        FontSize="10" 
                        FontWeight="SemiBold"
                        Margin="0,3,0,0" 
                        Visibility="Hidden"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,15">
                    <TextBlock Text="Korisničko Ime" Foreground="{DynamicResource PrimaryText}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox Name="tbKorisnickoIme" Background="{DynamicResource WindowBackground}" Foreground="{DynamicResource PrimaryText}" BorderBrush="{DynamicResource BorderColor}" FontSize="15" Padding="5"/>
                    <TextBlock x:Name="lblKorisnickoImeError" 
                        Text="" 
                        Foreground="Red" 
                        FontSize="10" 
                        FontWeight="SemiBold"
                        Margin="0,3,0,0" 
                        Visibility="Hidden"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,15">
                    <TextBlock Text="Email" Foreground="{DynamicResource PrimaryText}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox Name="tbEmail" Background="{DynamicResource WindowBackground}" Foreground="{DynamicResource PrimaryText}" BorderBrush="{DynamicResource BorderColor}" FontSize="15" Padding="5"/>
                    <TextBlock x:Name="lblEmailError" 
                        Text="" 
                        Foreground="Red" 
                        FontSize="10" 
                        FontWeight="SemiBold"
                        Margin="0,3,0,0" 
                        Visibility="Hidden"/>
                </StackPanel>

                <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,0,15">
                    <TextBlock Text="Spol" Foreground="{DynamicResource PrimaryText}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <ComboBox Name="cmbSpol" Background="{DynamicResource WindowBackground}" Foreground="{DynamicResource PrimaryText}" BorderBrush="{DynamicResource BorderColor}" FontSize="15" Padding="5"/>
                    <TextBlock FontSize="10" Margin="0,3,0,0" FontWeight="SemiBold"/>
                </StackPanel>

                <StackPanel Grid.Row="2" Grid.Column="2" Margin="0,0,0,15">
                    <TextBlock Text="Grad" Foreground="{DynamicResource PrimaryText}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <ComboBox Name="cmbGrad" Background="{DynamicResource WindowBackground}" Foreground="{DynamicResource PrimaryText}" BorderBrush="{DynamicResource BorderColor}" FontSize="15" Padding="5"/>
                    <TextBlock FontSize="10" Margin="0,3,0,0" FontWeight="SemiBold"/>
                </StackPanel>

                <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,0,0,15">
                    <TextBlock Text="JMBG" Foreground="{DynamicResource PrimaryText}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox Name="tbJMBG" Background="{DynamicResource WindowBackground}" Foreground="{DynamicResource PrimaryText}" BorderBrush="{DynamicResource BorderColor}" FontSize="15" Padding="5"/>
                    <TextBlock x:Name="lblJMBGError" 
                        Text="" 
                        Foreground="Red" 
                        FontSize="10" 
                        FontWeight="SemiBold"
                        Margin="0,3,0,0" 
                        Visibility="Hidden"/>
                </StackPanel>

                <StackPanel Grid.Row="3" Grid.Column="2" Margin="0,0,0,15">
                    <TextBlock Text="Datum Rođenja" Foreground="{DynamicResource PrimaryText}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <DatePicker Name="dtpDatumRodjenja" Background="{DynamicResource WindowBackground}" Foreground="{DynamicResource PrimaryText}" BorderBrush="{DynamicResource BorderColor}" FontSize="15" Padding="3"/>
                    <TextBlock x:Name="lblDatumRodjenjaError" 
                        Text="" 
                        Foreground="Red" 
                        FontSize="10" 
                        FontWeight="SemiBold"
                        Margin="0,3,0,0" 
                        Visibility="Hidden"/>
                </StackPanel>

                <StackPanel Grid.Row="4" Grid.Column="0" Margin="0,10,0,0">
                    <TextBlock Text="Lozinka" Foreground="{DynamicResource PrimaryText}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <PasswordBox Name="pbLozinka" Background="{DynamicResource WindowBackground}" Foreground="{DynamicResource PrimaryText}" BorderBrush="{DynamicResource BorderColor}" FontSize="15" Padding="5"/>
                    <TextBlock x:Name="lblLozinkaError" 
                        Text="" 
                        MaxWidth="400"
                        TextWrapping="Wrap"
                        Foreground="Red" 
                        FontSize="10" 
                        FontWeight="SemiBold"
                        Margin="0,3,0,0" 
                        Visibility="Hidden"/>
                </StackPanel>

                <StackPanel Grid.Row="4" Grid.Column="2" Margin="0,10,0,0">
                    <TextBlock FontSize="14" Margin="0,0,0,5"/>
                    <Button  
                        Name="btnSpasi"
                        Content="Sačuvaj" 
                        FontSize="15" 
                        FontWeight="Bold"
                        Background="{DynamicResource AccentColor}" 
                        Foreground="White" 
                        Padding="50,8" 
                        HorizontalAlignment="Right" 
                        VerticalAlignment="Bottom"
                        Cursor="Hand" 
                        Click="BtnSpasi_Click" />
                    <TextBlock x:Name="lblDuplikatError" 
                        Text="" 
                        Foreground="Red" 
                        FontSize="10" 
                        FontWeight="SemiBold"
                        Margin="0,3,0,0" 
                        Visibility="Hidden"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
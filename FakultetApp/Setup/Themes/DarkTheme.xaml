<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="WindowBackground" Color="#212120"/>
    <SolidColorBrush x:Key="CardBackground" Color="#1E1E1E"/>
    <SolidColorBrush x:Key="PrimaryText" Color="#F7FAFC"/>
    <SolidColorBrush x:Key="SecondaryText" Color="FloralWhite"/>
    <SolidColorBrush x:Key="BorderColor" Color="#2D3748"/>
    <SolidColorBrush x:Key="AccentColor" Color="#2e2e2c"/>
    <SolidColorBrush x:Key="Error" Color="Red"/>
    <SolidColorBrush x:Key="Naslov" Color="FloralWhite"/>

    <!-- STIL ZA COMBOBOX (Prozirni trik koji ne kvari DisplayMemberPath) -->
    <Style TargetType="ComboBox">
        <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
        <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="8,5"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <!-- 1. Naš vlastiti dizajn koji 100% sluša tvoje Dark/Light boje -->
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="30"/>
                                </Grid.ColumnDefinitions>

                                <!-- Ovaj dio garantuje da DisplayMemberPath radi normalno -->
                                <ContentPresenter Grid.Column="0" 
                                                  Margin="{TemplateBinding Padding}" 
                                                  Content="{TemplateBinding SelectionBoxItem}" 
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" 
                                                  ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}" 
                                                  VerticalAlignment="Center" 
                                                  HorizontalAlignment="Left" 
                                                  IsHitTestVisible="False"/>

                                <!-- Strelica menija -->
                                <Path Grid.Column="1" 
                                      Data="M 0 0 L 4 4 L 8 0 Z" 
                                      Fill="{DynamicResource PrimaryText}" 
                                      HorizontalAlignment="Center" 
                                      VerticalAlignment="Center" 
                                      IsHitTestVisible="False"/>
                            </Grid>
                        </Border>

                        <!-- 2. "Nevidljivi" pravi ComboBox kliker koji pokriva sve i otvara meni -->
                        <ToggleButton Opacity="0" 
                                      Cursor="Hand"
                                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"/>

                        <!-- 3. Padajući meni -->
                        <Popup IsOpen="{TemplateBinding IsDropDownOpen}" Placement="Bottom" AllowsTransparency="True" PopupAnimation="Slide">
                            <Border Background="{DynamicResource CardBackground}" 
                                    BorderBrush="{DynamicResource BorderColor}" 
                                    BorderThickness="1" 
                                    MinWidth="{Binding ActualWidth, ElementName=border}" 
                                    MaxHeight="{TemplateBinding MaxDropDownHeight}" 
                                    CornerRadius="4" 
                                    Margin="0,2,0,0">
                                <ScrollViewer>
                                    <ItemsPresenter/>
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- STIL ZA POJEDINAČNE STAVKE U COMBOBOXU -->
    <Style TargetType="ComboBoxItem">
        <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
        <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
        <Setter Property="Padding" Value="8,5"/>
    </Style>

    <!-- STIL ZA DATEPICKER (Rješava bijelu pozadinu polja za unos) -->
    <Style TargetType="DatePicker">
        <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
        <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
    </Style>

    <Style TargetType="DatePickerTextBox">
        <!-- Postavljamo pozadinu unutrašnjeg polja na prozirno, kako bi se vidjela prava pozadina DatePicker-a -->
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
    </Style>
    
</ResourceDictionary>
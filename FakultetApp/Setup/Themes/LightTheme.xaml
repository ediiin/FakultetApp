<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <SolidColorBrush x:Key="WindowBackground" Color="#F5F5F5"/>
    <SolidColorBrush x:Key="CardBackground" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="PrimaryText" Color="#2D3748"/>
    <SolidColorBrush x:Key="SecondaryText" Color="FloralWhite"/>
    <SolidColorBrush x:Key="BorderColor" Color="#ebebed"/>
    <SolidColorBrush x:Key="AccentColor" Color="#3182CE"/>
    <SolidColorBrush x:Key="Error" Color="Red"/>
    <SolidColorBrush x:Key="Naslov" Color="#3182CE"/>

    <!-- Stilovi za ComboBox u Svetloj temi -->
    <Style TargetType="ComboBox">
        <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
        <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
    </Style>
    <Style TargetType="ComboBoxItem">
        <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
        <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
    </Style>

    <!-- Stilovi za DatePicker u Svetloj temi -->
    <Style TargetType="DatePicker">
        <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
        <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
    </Style>
    <Style TargetType="DatePickerTextBox">
        <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
        <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
    </Style>
    <!-- Hakovanje fabričkih Windows boja za ComboBox i DatePicker -->
    <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="#2D3748"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#3182CE"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#FFFFFF"/>

    <!-- STIL ZA DATAGRID ROW (Uklonjen okidač za selekciju) -->
    <Style TargetType="DataGridRow">
        <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
        <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <!-- Ovdje smo obrisali Style.Triggers tako da red više uopšte ne mijenja pozadinu -->
    </Style>

    <!-- STIL ZA DATAGRID CELL (Gasi svaku promjenu boje prilikom klika) -->
    <Style TargetType="DataGridCell">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Padding" Value="5,0"/>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <!-- Pozadina ostaje prozirna kako bi se vidjela normalna ili naizmjenična boja reda -->
                <Setter Property="Background" Value="Transparent"/>
                <!-- Tekst ostaje originalne boje, ne mijenja se u bijelu -->
                <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
            </Trigger>
        </Style.Triggers>
    </Style>
</ResourceDictionary>
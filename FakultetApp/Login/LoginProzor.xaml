<Window x:Class="FakultetApp.Login.LoginProzor"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FakultetApp.Login"
        mc:Ignorable="d"
        Title="Prijava na sistem" Height="420" Width="800" ResizeMode="NoResize" WindowStartupLocation="CenterScreen">
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row ="0" Margin="0,0,0,30" HorizontalAlignment="Center">
            <TextBlock Text="DOBRODOŠLI" FontSize="27" FontWeight="Bold" Foreground="#1A237E" FontFamily="Arial Black"/>
            <TextBlock Text="Unesite podatke za prijavu" FontSize="14" Foreground="Gray" HorizontalAlignment="Center" Margin="0,5,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,0,0,15" Width="650">
            <TextBlock Text="Korisničko ime ili email" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="#333"/>
            <TextBox x:Name="txtKorisnik" Height="35" VerticalContentAlignment="Center" Padding="5" FontSize="16"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,0,0,25" Width="650">
            <TextBlock Text="Lozinka" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,5" Foreground="#333"/>
            <PasswordBox x:Name="txtLozinka" Height="35" VerticalContentAlignment="Center" Padding="5" FontSize="16"/>
        </StackPanel>

        <StackPanel Grid.Row="3">
            <TextBlock x:Name="lblGreska" Text="" Foreground="Red" FontSize="12" Margin="0,0,0,10" HorizontalAlignment="Center" Visibility="Collapsed"/>
            <Button x:Name="btnLogin" Content="Prijavi se" Height="40" Width="200" Background="#1A237E" Foreground="White" FontSize="14" FontWeight="Bold" Click="BtnLogin_Click"/>
        </StackPanel>
    </Grid>
</Window>

<Window x:Class="FakultetApp.Login.LoginProzor"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FakultetApp.Login"
        mc:Ignorable="d"
        WindowStyle="None"
        Height="420" 
        Width="800" 
        ResizeMode="NoResize" 
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBackground}">

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TITLE BAR -->

        <Border Grid.Row="0"
            Background="{DynamicResource CardBackground}"
            BorderBrush="{DynamicResource BorderColor}"
            BorderThickness="0,0,0,1"
            MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="55"/>
                    <ColumnDefinition Width="40"/>
                </Grid.ColumnDefinitions>

                <!-- Naslov -->

                <TextBlock
                Text="🎓 Prijava na sistem"
                Margin="15,0"
                VerticalAlignment="Center"
                FontWeight="Bold"
                FontSize="14"
                Foreground="{DynamicResource PrimaryText}"/>

                <!-- Dark Mode -->

                <ToggleButton
                x:Name="btnThemeToggle"
                Grid.Column="1"
                Margin="5"
                Cursor="Hand"
                Background="Transparent"
                BorderThickness="0"
                Foreground="{DynamicResource PrimaryText}"
                Content="🌙"
                FontSize="16"
                Click="BtnThemeToggle_Click"/>

                <!-- Close -->

                <Button
                Grid.Column="2"
                Content="✕"
                Background="Transparent"
                BorderThickness="0"
                Foreground="{DynamicResource PrimaryText}"
                Cursor="Hand"
                Click="BtnClose_Click"/>

            </Grid>

        </Border>

        <!-- SADRŽAJ -->

        <Grid Grid.Row="1" Margin="30">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0"
                    Margin="0,10,0,25"
                    HorizontalAlignment="Center">

                <TextBlock
                Text="DOBRODOŠLI"
                FontSize="27"
                FontWeight="Bold"
                FontFamily="Arial Black"
                Foreground="{DynamicResource Naslov}"
                HorizontalAlignment="Center"/>

                <TextBlock
                Text="Unesite podatke za prijavu"
                FontSize="14"
                Margin="0,5,0,0"
                HorizontalAlignment="Center"
                Foreground="{DynamicResource SecondaryText}"/>

            </StackPanel>

            <StackPanel Grid.Row="1"
                    Width="650"
                    Margin="0,0,0,15">

                <TextBlock
                Text="Korisničko ime ili email"
                FontWeight="SemiBold"
                Margin="0,0,0,5"
                Foreground="{DynamicResource PrimaryText}"/>

                <TextBox
                x:Name="txtKorisnik"
                Height="35"
                FontSize="16"
                Padding="5"
                VerticalContentAlignment="Center"
                Background="{DynamicResource CardBackground}"
                Foreground="{DynamicResource PrimaryText}"/>

            </StackPanel>

            <StackPanel Grid.Row="2"
                    Width="650"
                    Margin="0,0,0,25">

                <TextBlock
                Text="Lozinka"
                FontWeight="SemiBold"
                Margin="0,0,0,5"
                Foreground="{DynamicResource PrimaryText}"/>

                <PasswordBox
                x:Name="txtLozinka"
                Height="35"
                FontSize="16"
                Padding="5"
                VerticalContentAlignment="Center"
                Background="{DynamicResource CardBackground}"
                Foreground="{DynamicResource PrimaryText}"/>

            </StackPanel>

            <StackPanel Grid.Row="3">

                <TextBlock
                x:Name="lblGreska"
                Visibility="Collapsed"
                Margin="0,0,0,10"
                HorizontalAlignment="Center"
                Foreground="{DynamicResource Error}"/>

                <Button
                x:Name="btnLogin"
                Width="200"
                Height="40"
                Content="Prijavi se"
                Background="{DynamicResource AccentColor}"
                Foreground="White"
                FontWeight="Bold"
                Click="BtnLogin_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>